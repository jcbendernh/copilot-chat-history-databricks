<svg xmlns="http://www.w3.org/2000/svg" width="1800" height="1200" viewBox="0 0 1800 1200">
  <defs>
    <style>
      .title { font: 700 28px Arial, sans-serif; fill: #111827; }
      .lane { fill: #f8fafc; stroke: #cbd5e1; stroke-width: 2; rx: 18; ry: 18; }
      .laneTitle { font: 700 22px Arial, sans-serif; fill: #0f172a; }
      .box { fill: #ffffff; stroke: #334155; stroke-width: 2; rx: 14; ry: 14; }
      .boxBlue { fill: #dbeafe; stroke: #1d4ed8; stroke-width: 2; rx: 14; ry: 14; }
      .boxGreen { fill: #dcfce7; stroke: #15803d; stroke-width: 2; rx: 14; ry: 14; }
      .boxAmber { fill: #fef3c7; stroke: #b45309; stroke-width: 2; rx: 14; ry: 14; }
      .boxPurple { fill: #ede9fe; stroke: #7c3aed; stroke-width: 2; rx: 14; ry: 14; }
      .text { font: 18px Arial, sans-serif; fill: #111827; }
      .small { font: 16px Arial, sans-serif; fill: #111827; }
      .arrow { stroke: #475569; stroke-width: 3; fill: none; marker-end: url(#arrowhead); }
      .dashed { stroke-dasharray: 10 8; }
    </style>
    <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#475569" />
    </marker>
  </defs>

  <text x="900" y="45" text-anchor="middle" class="title">Copilot Chat History Databricks - Process Flow</text>

  <rect x="30" y="80" width="1740" height="220" class="lane" />
  <text x="55" y="115" class="laneTitle">1. Source Setup</text>

  <rect x="80" y="150" width="290" height="90" class="boxBlue" />
  <text x="225" y="185" text-anchor="middle" class="text">Dataverse Synapse Link</text>
  <text x="225" y="212" text-anchor="middle" class="small">Exports conversationtranscript</text>
  <text x="225" y="234" text-anchor="middle" class="small">and systemuser tables</text>

  <rect x="450" y="150" width="320" height="90" class="boxBlue" />
  <text x="610" y="185" text-anchor="middle" class="text">Azure Data Lake Storage</text>
  <text x="610" y="212" text-anchor="middle" class="small">CDM container with model.json</text>
  <text x="610" y="234" text-anchor="middle" class="small">and CSV partition files</text>

  <rect x="860" y="150" width="360" height="90" class="boxBlue" />
  <text x="1040" y="185" text-anchor="middle" class="text">Unity Catalog External Location</text>
  <text x="1040" y="212" text-anchor="middle" class="small">Volume-backed access to ADLS</text>
  <text x="1040" y="234" text-anchor="middle" class="small">No credentials stored in notebook code</text>

  <line x1="370" y1="195" x2="450" y2="195" class="arrow" />
  <line x1="770" y1="195" x2="860" y2="195" class="arrow" />

  <rect x="30" y="330" width="1740" height="320" class="lane" />
  <text x="55" y="365" class="laneTitle">2. Bronze to Silver Ingestion</text>

  <rect x="70" y="420" width="360" height="130" class="boxAmber" />
  <text x="250" y="455" text-anchor="middle" class="text">Notebook 1</text>
  <text x="250" y="485" text-anchor="middle" class="text">CDM to Unity Catalog Auto Loader Ingestion</text>
  <text x="250" y="515" text-anchor="middle" class="small">Reads parameters and entity list</text>

  <rect x="500" y="420" width="260" height="130" class="box" />
  <text x="630" y="460" text-anchor="middle" class="text">Parse model.json</text>
  <text x="630" y="490" text-anchor="middle" class="small">Build Spark schemas</text>
  <text x="630" y="515" text-anchor="middle" class="small">for selected CDM entities</text>

  <rect x="820" y="420" width="260" height="130" class="box" />
  <text x="950" y="460" text-anchor="middle" class="text">Schema Verification</text>
  <text x="950" y="490" text-anchor="middle" class="small">Validate CSV parsing</text>
  <text x="950" y="515" text-anchor="middle" class="small">for conversationtranscript</text>

  <rect x="1140" y="420" width="280" height="130" class="box" />
  <text x="1280" y="460" text-anchor="middle" class="text">Auto Loader Stream</text>
  <text x="1280" y="490" text-anchor="middle" class="small">Incremental CSV to Delta ingestion</text>
  <text x="1280" y="515" text-anchor="middle" class="small">with checkpoints and CDF enabled</text>

  <rect x="1480" y="420" width="220" height="130" class="boxGreen" />
  <text x="1590" y="460" text-anchor="middle" class="text">Silver Tables</text>
  <text x="1590" y="490" text-anchor="middle" class="small">silver.dataverse</text>
  <text x="1590" y="515" text-anchor="middle" class="small">conversationtranscript, systemuser</text>

  <line x1="430" y1="485" x2="500" y2="485" class="arrow" />
  <line x1="760" y1="485" x2="820" y2="485" class="arrow" />
  <line x1="1080" y1="485" x2="1140" y2="485" class="arrow" />
  <line x1="1420" y1="485" x2="1480" y2="485" class="arrow" />

  <rect x="30" y="680" width="1740" height="350" class="lane" />
  <text x="55" y="715" class="laneTitle">3. Silver to Gold Transformation</text>

  <rect x="70" y="770" width="340" height="160" class="boxAmber" />
  <text x="240" y="805" text-anchor="middle" class="text">Notebook 2</text>
  <text x="240" y="835" text-anchor="middle" class="text">Conversations - Initial Ingestion</text>
  <text x="240" y="865" text-anchor="middle" class="small">Load transcript data from Silver</text>
  <text x="240" y="890" text-anchor="middle" class="small">Parse JSON, explode messages</text>
  <text x="240" y="915" text-anchor="middle" class="small">Join systemuser and enrich sender fields</text>

  <rect x="470" y="770" width="260" height="160" class="boxGreen" />
  <text x="600" y="815" text-anchor="middle" class="text">Gold Table Created</text>
  <text x="600" y="845" text-anchor="middle" class="small">gold.copilot.conversations</text>
  <text x="600" y="875" text-anchor="middle" class="small">Overwrite on first full load</text>
  <text x="600" y="905" text-anchor="middle" class="small">Stores transformed conversation rows</text>

  <rect x="790" y="770" width="260" height="160" class="boxPurple" />
  <text x="920" y="815" text-anchor="middle" class="text">Baseline Stored</text>
  <text x="920" y="845" text-anchor="middle" class="small">cdf.baseline_version</text>
  <text x="920" y="875" text-anchor="middle" class="small">Saved as a Gold table property</text>
  <text x="920" y="905" text-anchor="middle" class="small">Used by incremental notebook</text>

  <rect x="1110" y="770" width="340" height="160" class="boxAmber" />
  <text x="1280" y="805" text-anchor="middle" class="text">Notebook 3</text>
  <text x="1280" y="835" text-anchor="middle" class="text">Conversations - Incremental Load</text>
  <text x="1280" y="865" text-anchor="middle" class="small">Read Silver CDF from next version</text>
  <text x="1280" y="890" text-anchor="middle" class="small">Repeat same transformations</text>
  <text x="1280" y="915" text-anchor="middle" class="small">Append new rows and advance checkpoint</text>

  <rect x="1510" y="770" width="210" height="160" class="boxGreen" />
  <text x="1615" y="815" text-anchor="middle" class="text">Updated Gold</text>
  <text x="1615" y="845" text-anchor="middle" class="small">Append-only new records</text>
  <text x="1615" y="875" text-anchor="middle" class="small">Baseline moved forward</text>
  <text x="1615" y="905" text-anchor="middle" class="small">Ready for reporting</text>

  <line x1="410" y1="850" x2="470" y2="850" class="arrow" />
  <line x1="730" y1="850" x2="790" y2="850" class="arrow" />
  <line x1="1050" y1="850" x2="1110" y2="850" class="arrow" />
  <line x1="1450" y1="850" x2="1510" y2="850" class="arrow" />

  <line x1="1590" y1="550" x2="1590" y2="730" class="arrow dashed" />
  <line x1="920" y1="930" x2="920" y2="980" class="arrow dashed" />
  <line x1="920" y1="980" x2="1280" y2="980" class="arrow dashed" />
  <line x1="1280" y1="980" x2="1280" y2="930" class="arrow dashed" />

  <rect x="520" y="1060" width="760" height="95" class="boxBlue" />
  <text x="900" y="1095" text-anchor="middle" class="text">Consumption</text>
  <text x="900" y="1125" text-anchor="middle" class="small">Power BI reads the gold.copilot.conversations table for conversation summary and detail reporting</text>
</svg>
